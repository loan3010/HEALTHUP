# --- SMS (OTP checkout khách + tin nhắn mã tra cứu) ---
# console = chỉ log ra terminal (mặc định dev)
#   → API luôn trả devPlainOtp (mockup checkout hiện đúng mã). Production: đổi sang esms/webhook.
# webhook = POST JSON { phone, message } tới SMS_WEBHOOK_URL
# esms    = ESMS.VN (cần ESMS_API_KEY, ESMS_SECRET_KEY) — không trả devPlainOtp
SMS_PROVIDER=console
# SMS_WEBHOOK_URL=https://...
FRONTEND_PUBLIC_URL=http://localhost:4200
OTP_PEPPER=doi_chuoi_bi_mat_dai_32_ky_tu
# Chỉ dev: trả mã OTP plain trong JSON /guest-checkout-otp/send (không bật production)
SMS_DEBUG_RETURN_OTP=false
# ESMS_API_KEY=
# ESMS_SECRET_KEY=
# ESMS_BRANDNAME=

# Badge tự động (GET sản phẩm — không lưu từ form admin)
# NEW: sản phẩm tạo trong N ngày gần đây
NEW_BADGE_DAYS=14
# HOT: tổng quantity trong đơn (không cancelled) trong window ngày ≥ ngưỡng
HOT_BADGE_DAYS=7
HOT_BADGE_MIN_ORDERS=50
